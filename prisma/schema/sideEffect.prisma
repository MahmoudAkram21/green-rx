
// ============================================
// SIDE EFFECTS
// ============================================

model SideEffect {
  id              Int                 @id @default(autoincrement())
  name            String              @unique // English name
  nameAr          String? // Arabic name
  createdBy       SideEffectCreatedBy @default(Admin)
  status          SideEffectStatus    @default(Approved)
  createdByUserId Int? // for audit when createdBy=Patient
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  medicationSideEffects MedicationSideEffect[]
  patientSideEffects    PatientSideEffect[]
  tradeNameSideEffects  TradeNameSideEffect[]

  @@index([name])
  @@index([status])
  @@index([createdBy])
  @@map("side_effects")
}

model MedicationSideEffect {
  id                Int      @id @default(autoincrement())
  activeSubstanceId Int
  sideEffectId      Int
  frequency         String? // VeryCommon, Common, Uncommon, Rare, VeryRare, Unknown
  bodySystem        String? // GIT, Blood, Cardiac, Vascular, NervousSystem, etc.
  createdAt         DateTime @default(now())

  activeSubstance ActiveSubstance @relation(fields: [activeSubstanceId], references: [id], onDelete: Cascade)
  sideEffect      SideEffect      @relation(fields: [sideEffectId], references: [id], onDelete: Cascade)

  @@unique([activeSubstanceId, sideEffectId])
  @@index([activeSubstanceId])
  @@index([sideEffectId])
  @@map("medication_side_effects")
}

model TradeNameSideEffect {
  id           Int      @id @default(autoincrement())
  tradeNameId  Int
  sideEffectId Int
  frequency    String? // VeryCommon, Common, Uncommon, Rare, VeryRare, Unknown
  bodySystem   String? // GIT, Blood, Cardiac, etc.
  createdAt    DateTime @default(now())

  tradeName  TradeName  @relation(fields: [tradeNameId], references: [id], onDelete: Cascade)
  sideEffect SideEffect @relation(fields: [sideEffectId], references: [id], onDelete: Cascade)

  @@unique([tradeNameId, sideEffectId])
  @@index([tradeNameId])
  @@index([sideEffectId])
  @@map("trade_name_side_effects")
}

model PatientSideEffect {
  id                Int      @id @default(autoincrement())
  patientId         Int
  patientMedicineId Int
  sideEffectId      Int
  severity          String? // Mild, Moderate, Severe
  notes             String?
  reportedAt        DateTime @default(now())
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  patient         Patient         @relation(fields: [patientId], references: [id], onDelete: Cascade)
  patientMedicine PatientMedicine @relation(fields: [patientMedicineId], references: [id], onDelete: Cascade)
  sideEffect      SideEffect      @relation(fields: [sideEffectId], references: [id], onDelete: Cascade)

  @@unique([patientId, patientMedicineId, sideEffectId])
  @@index([patientId])
  @@index([patientMedicineId])
  @@index([sideEffectId])
  @@map("patient_side_effects")
}
