  unknownMusculoskeletal    Json?
  unknownPsychiatric        Json?
  unknownHepatobiliary      Json?
  unknownRenal              Json?
  unknownSkin               Json?
  unknownRespiratory        Json?
  unknownImmune             Json?
  unknownVascular           Json?
  unknownEar                Json?
  unknownGIT                Json?
  unknownGeneral            Json?
  unknownMetabolism         Json?
  unknownEye                Json?
  unknownBlood              Json?
  unknownCardiac            Json?
  unknownInfections         Json?
  unknownEndocrine          Json?

  // Additional Fields
  additiveRMM          String?
  pregnancyCategory    String?
  additionalMonitoring String?
  highlightedWarning   String?
  version              Int       @default(1)
  isActive             Boolean   @default(true)
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
  deletedAt            DateTime?

  // Relations
  tradeNames                      TradeName[]
  diseaseActiveSubstanceWarnings  DiseaseActiveSubstanceWarning[]
  diseaseWarningRules             DiseaseWarningRule[]
  medicineAlternatives            MedicineAlternative[]           @relation("PrimarySubstance")
  alternativeTo                   MedicineAlternative[]           @relation("AlternativeSubstance")
  adverseReactions                AdverseDrugReaction[]
  patientMedicines                PatientMedicine[]
  addMedicineRequests             AddMedicineRequest[]
  medicationSideEffects           MedicationSideEffect[]
  adrReports                      AdrReport[]
  activeSubstancePatientAllergies ActiveSubstancePatientAllergy[]
  allergenActiveSubstances        AllergenActiveSubstance[]

  @@index([name])
  @@index([isActive])
  @@map("active_substances")
}

model Classification {
  id                             Int                            @id @default(autoincrement())
  name                           String
  description                    String?
  isActive                       Boolean                        @default(true)
  createdAt                      DateTime                       @default(now())
  updatedAt                      DateTime                       @updatedAt
  activeSubstances               ActiveSubstance[]
  classificationPatientAllergies ClassificationPatientAllergy[]

  @@index([name])
  @@index([isActive])
  @@map("classifications")
}

model TradeName {
  id                  Int                        @id @default(autoincrement())
  title               String
  activeSubstanceId   Int
  companyId           Int?
  warningNotification String? // for doctors only
  barCode             String?
  isActive            Boolean                    @default(true)
  createdAt           DateTime                   @default(now())
  updatedAt           DateTime                   @updatedAt
  deletedAt           DateTime?

  // Relations
  activeSubstance              ActiveSubstance               @relation(fields: [activeSubstanceId], references: [id], onDelete: Cascade)
  company                      Company?                      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  contractingCompanyTradeNames ContractingCompanyTradeName[]
  drugInteractionAlerts        DrugInteractionAlert[]
  batchHistories               BatchHistory[]
  adverseReactions             AdverseDrugReaction[]
  patientMedicines             PatientMedicine[]
  addMedicineRequests          AddMedicineRequest[]
  tradeNameSideEffects         TradeNameSideEffect[]
  excipientTradeName           ExcipientTradeName[]
  tradnamePatientAllergies     TradenamePatientAllergy[]
  companyInstructionsPdf       InstructionPdf?
  adrReports                   AdrReport[]

  @@index([title])
  @@index([activeSubstanceId])
  @@index([companyId])
  @@map("trade_names")
}

model InstructionPdf {
  id          Int       @id @default(autoincrement())
  url         String
  views       Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  tradeNameId Int       @unique
  tradeName   TradeName @relation(fields: [tradeNameId], references: [id], onDelete: Cascade)
}

model Excipient {
  id                        Int                       @id @default(autoincrement())
  name                      String
  description               String?
  isActive                  Boolean                   @default(true)
  createdAt                 DateTime                  @default(now())
  updatedAt                 DateTime                  @updatedAt
  excipientTradeName        ExcipientTradeName[]
  excipientPatientAllergies ExcipientPatientAllergy[]
  allergenExcipients        AllergenExcipient[]
}

model ExcipientTradeName {
  id          Int       @id @default(autoincrement())
  excipientId Int
  tradeNameId Int
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  excipient   Excipient @relation(fields: [excipientId], references: [id], onDelete: Cascade)
  tradeName   TradeName @relation(fields: [tradeNameId], references: [id], onDelete: Cascade)

  @@unique([excipientId, tradeNameId])
}
